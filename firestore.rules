// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: tasks
// Fields:
//   - title: string (required, 1-100 chars)
//   - description: string (optional, 0-500 chars)
//   - deadline: timestamp (required)
//   - priority: string (required, low|medium|high)
//   - status: string (required, todo|in-progress|done)
//   - userId: string (required, matches owner)
//   - createdAt: timestamp (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidTask(data) {
      let requiredFields = ['title', 'deadline', 'priority', 'status', 'userId', 'createdAt'];
      let allowedFields = ['title', 'description', 'deadline', 'priority', 'status', 'userId', 'createdAt'];
      
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(allowedFields) &&
             data.title is string && data.title.size() >= 1 && data.title.size() <= 100 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 500)) &&
             data.deadline is timestamp &&
             data.priority in ['low', 'medium', 'high'] &&
             data.status in ['todo', 'in-progress', 'done'] &&
             data.userId == request.auth.uid &&
             data.createdAt is timestamp;
    }

    match /tasks/{taskId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidTask(request.resource.data);
      allow update: if isAuthenticated() && 
                      isDocOwner() && 
                      isValidTask(request.resource.data) &&
                      request.resource.data.userId == resource.data.userId &&
                      request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }
  }
}
